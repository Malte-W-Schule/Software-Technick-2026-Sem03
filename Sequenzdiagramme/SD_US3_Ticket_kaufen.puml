@startuml SD_US3_Ticket_kaufen
title US3 – Ticket kaufen

actor "Teilnehmer" as User
participant "Client\n(Web/App)" as Client
participant "API Gateway" as API
participant "Ticket-Service" as TicketSvc
participant "Zahlungs-\nService" as PaySvc
database "Datenbank" as DB
participant "Benachrichtigungs-\nService" as Notif

User -> Client : Event suchen / URL aufrufen
Client -> API : GET /events?radius=...
API --> Client : Liste von Events
Client --> User : Events anzeigen

User -> Client : Event auswählen
Client -> API : GET /events/{eventId}
API --> Client : Event-Details\n(Ticket-Typen, Preise, QR-Code,\nMindestsumme, noch benötigter Betrag)
Client --> User : Event-Detail-Seite\n(inkl. Finanzstatus: "X € von Y € erreicht")

User -> Client : Ticket-Typ wählen & Kaufen klicken\n(Kategorie, Anzahl)
Client -> API : POST /events/{eventId}/tickets\n{category, quantity, price, payment_method}
API -> API : JWT-Token prüfen (Nutzer authentifiziert?)

API -> TicketSvc : Ticket-Kaufanfrage

TicketSvc -> DB : Verfügbarkeit prüfen\n(quantity <= remaining?)
DB --> TicketSvc : Bestand OK

TicketSvc -> DB : Mindestanzahl Teilnehmer prüfen
DB --> TicketSvc : Teilnehmeranzahl aktuell

TicketSvc -> PaySvc : Zahlung initiieren\n(amount, payment_method)
PaySvc -> PaySvc : Transaktion verarbeiten

alt Zahlung erfolgreich
    PaySvc --> TicketSvc : Zahlung bestätigt
    TicketSvc -> DB : Ticket anlegen & Bestand reduzieren\n(Teilnehmeranzahl +1)
    DB --> TicketSvc : ticketId

    alt Mindestanzahl Teilnehmer erreicht
        TicketSvc -> Notif : Veranstalter benachrichtigen\n("Mindestanzahl erreicht – Event findet statt!")
        Notif --> User : Push / E-Mail Benachrichtigung
    end

    TicketSvc -> TicketSvc : PDF & QR-Code generieren
    TicketSvc -> Notif : Ticket per E-Mail senden (PDF + QR-Code)
    Notif --> User : E-Mail mit Ticket (PDF / QR-Code)
    TicketSvc --> API : 201 Created\n{ticketId, qr_code, pdf_url}
    API --> Client : Buchungsbestätigung
    Client --> User : "Ticket erfolgreich gekauft"\n+ Download-Link

else Zahlung fehlgeschlagen
    PaySvc --> TicketSvc : Zahlung abgelehnt
    TicketSvc --> API : 402 Payment Required
    API --> Client : Fehlermeldung
    Client --> User : "Zahlung fehlgeschlagen – bitte erneut versuchen"
end

@enduml
